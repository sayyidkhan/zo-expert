# Copy this file to .env and fill in the values you want to use locally.
# Keep this file committed; never commit your real .env file.

# Required for OpenAI-powered owner profile building, consultation answers,
# escalation checks, and owner brief generation.
OPENAI_API_KEY=

# Optional for Zo Expert. Use only when external/public enrichment is needed.
EXA_API_KEY=

# Local backend configuration.
API_PORT=8787

# Frontend should call the local backend only. Do not expose raw API keys to Vite.
VITE_API_BASE_URL=http://localhost:8787
